		<TabIconActive>A_AbilitiesTabActiveIcon</TabIconActive>
		<Pieces>AAP_ShowBasicCheckbox</Pieces>
		<Pieces>AAP_ShowGeneralCheckbox</Pieces>
		<Pieces>VerticalLayoutBox:AAP_Layout</Pieces>
	</Page>

	<!-- PortRing Tab -->
	<Button item="ACTW_PR_SpellBookButton">
		<ScreenID>ACTW_PR_SpellBookButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<TooltipReference>Opens and closes Your Spellbook</TooltipReference>
		<Style_Checkbox>true</Style_Checkbox>
		<Template>BDT_BookBtnActionsWindow</Template>
		<Size>
			<CX>20</CX>
			<CY>20</CY>
		</Size>
		<Location>
			<X>5</X>
			<Y>2</Y>
		</Location>
	</Button>

	<Combobox item="ACTW_PR_ClassCombo">
		<ScreenID>ACTW_PR_ClassCombo</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<AutoStretchList>true</AutoStretchList>
		<Location>
			<X>30</X>
			<Y>2</Y>
		</Location>
		<Size>
			<CX>120</CX>
			<CY>21</CY>
		</Size>
		<ListHeight>200</ListHeight>
		<Button>BDT_Combo</Button>
		<Style_Border>true</Style_Border>
	</Combobox>

	<Label item="ACTW_PR_FilterLabel">
		<ScreenID>ACTW_PR_FilterLabel</ScreenID>
		<Location>
			<X>161</X>
			<Y>4</Y>
		</Location>
		<Size>
			<CX>40</CX>
			<CY>20</CY>
		</Size>
		<AlignRight>true</AlignRight>
		<Text>Search</Text>
	</Label>

	<Editbox item="ACTW_PR_FilterEditBox">
		<ScreenID>ACTW_PR_FilterEditBox</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>2</TopAnchorOffset>
		<BottomAnchorOffset>23</BottomAnchorOffset>
		<LeftAnchorOffset>205</LeftAnchorOffset>
		<RightAnchorOffset>345</RightAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>true</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>true</RightAnchorToLeft>
		<Style_Border>true</Style_Border>
	</Editbox>
	
	<Button item = "ACTW_PR_ResetBtn">
		<ScreenID>ACTW_PR_ResetBtn</ScreenID>
		<Font>2</Font>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>2</TopAnchorOffset>
		<BottomAnchorOffset>22</BottomAnchorOffset>
		<LeftAnchorOffset>350</LeftAnchorOffset>
		<RightAnchorOffset>400</RightAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>true</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>true</RightAnchorToLeft>
		<Text>Reset</Text>
		<Template>BDT_SmallNormal</Template>
	</Button>

	<Listbox item="ACTW_PR_ListBox">
		<ScreenID>ACTW_PR_ListBox</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<AutoStretch>true</AutoStretch>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<LeftAnchorOffset>2</LeftAnchorOffset>
		<TopAnchorOffset>25</TopAnchorOffset>
		<RightAnchorOffset>2</RightAnchorOffset>
		<BottomAnchorOffset>2</BottomAnchorOffset>
		<Style_Border>true</Style_Border>
		<Style_VScroll>true</Style_VScroll>
		<Columns>
			<Heading>Gem</Heading>
			<Width>50</Width>
		</Columns>
		<Columns>
			<Heading>Name</Heading>
			<Width>175</Width>
		</Columns>
		<Columns>
			<Heading>Location</Heading>
			<Width>300</Width>
		</Columns>
	</Listbox>
	<Page item="ACTW_PortRing_Page">
		<ScreenID>ACTW_PortRing_Page</ScreenID>		
		<RelativePosition>true</RelativePosition>
		<Style_VScroll>false</Style_VScroll>
		<Style_HScroll>false</Style_HScroll>
		<Style_Transparent>false</Style_Transparent>
		<DrawTemplate>WDT_Def</DrawTemplate>
		<TabText>Rituals</TabText>
		<TabIcon>A_MainTabIcon</TabIcon>
		<TabIconActive>A_MainTabActiveIcon</TabIconActive>
		<Pieces>ACTW_PR_SpellBookButton</Pieces>
		<Pieces>ACTW_PR_ClassCombo</Pieces>
		<Pieces>ACTW_PR_FilterLabel</Pieces>
		<Pieces>ACTW_PR_FilterEditBox</Pieces>
		<Pieces>ACTW_PR_ResetBtn</Pieces>
		<Pieces>ACTW_PR_ListBox</Pieces>
	</Page>

	<!-- TabBox Brings all the Actions Pages Together -->

	<TabBox item = "ACTW_ActionsSubwindows">
		<ScreenID>ACTW_ActionsSubwindows</ScreenID>
		<!--<Font>3</Font>-->
		<RelativePosition>true</RelativePosition>

		<AutoStretch>true</AutoStretch>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>

		<TabBorderTemplate>FT_DefTabBorder</TabBorderTemplate>
		<PageBorderTemplate>FT_DefPageBorder</PageBorderTemplate>
		<Pages>ActionsAbilitiesPage</Pages>
		<Pages>ActionsDisciplinesPage</Pages>
		<Pages>ActionsSpellsPage</Pages>
		<Pages>ACTW_PortRing_Page</Pages>
		<Pages>ACTW_MacrosPage</Pages>
	</TabBox>

	<Screen item = "ActionsWindow">
		<RelativePosition>false</RelativePosition>
		<MinVSize>308</MinVSize>
		<MinHSize>500</MinHSize>
		<KeepOnScreen>true</KeepOnScreen>
		<KeepOnScreenOffset>
			<X>-3</X>
			<Y>-3</Y>
		</KeepOnScreenOffset>			
		<Text>Actions</Text>
		<Style_VScroll>false</Style_VScroll>
		<Style_HScroll>false</Style_HScroll>
		<Style_Transparent>false</Style_Transparent>
		<DrawTemplate>WDT_Rounded</DrawTemplate>
		<Style_Titlebar>true</Style_Titlebar>
		<Style_Closebox>true</Style_Closebox>
		<Style_Minimizebox>true</Style_Minimizebox>
		<Style_Border>true</Style_Border>
		<Style_Sizable>true</Style_Sizable>
		<Escapable>true</Escapable>
		<Pieces>ActionsButtonTemplate</Pieces>
		<Pieces>ActionsDecalButtonTemplate</Pieces>
		<Pieces>ActionsSpellButtonTemplate</Pieces>
		<Pieces>ActionsCheckBoxTemplate</Pieces>
		<Pieces>ACTW_ActionsSubwindows</Pieces>
	</Screen>

</XML>

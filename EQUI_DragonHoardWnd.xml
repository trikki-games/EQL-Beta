	</Label>

	<Editbox item="DH_SearchItem_Input">
		<ScreenID>DH_SearchItem_Input</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorToLeft>false</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<TooltipReference>Search by partial item name.</TooltipReference>
		<LeftAnchorOffset>220</LeftAnchorOffset>
		<TopAnchorOffset>2</TopAnchorOffset>
		<RightAnchorOffset>82</RightAnchorOffset>
		<BottomAnchorOffset>24</BottomAnchorOffset>
		<Style_Border>true</Style_Border>
	</Editbox>
	<Button item="DH_SearchItem_Button">
		<ScreenID>DH_SearchItem_Button</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorToLeft>false</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<Style_Checkbox>false</Style_Checkbox>
		<Style_Transparent>false</Style_Transparent>	
		<LeftAnchorOffset>80</LeftAnchorOffset>
		<TopAnchorOffset>2</TopAnchorOffset>
		<RightAnchorOffset>2</RightAnchorOffset>
		<BottomAnchorOffset>24</BottomAnchorOffset>
		<Text>Search</Text>
		<NoWrap>true</NoWrap>
		<TextAlignCenter>true</TextAlignCenter>
		<TextOffsetX>0</TextOffsetX>
		<Template>BDT_FindItem</Template>
	</Button>
	<Listbox item="DH_Item_List">
		<ScreenID>DH_Item_List</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<AutoStretch>true</AutoStretch>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<TopAnchorOffset>26</TopAnchorOffset>
		<BottomAnchorOffset>38</BottomAnchorOffset>
		<LeftAnchorOffset>2</LeftAnchorOffset>
		<RightAnchorOffset>2</RightAnchorOffset>
		<Style_Border>true</Style_Border>
		<Style_VScroll>true</Style_VScroll>
		<Columns>
			<Width>24</Width>
			<Heading></Heading>
		</Columns>
		<Columns>
			<Width>260</Width>
			<Heading>Item Name</Heading>
		</Columns>
		<Columns>
			<Width>35</Width>
			<Heading>Qty</Heading>
		</Columns>
	</Listbox>

	<Button item="DH_Retrieve_Button">
		<ScreenID>DH_Retrieve_Button</ScreenID>

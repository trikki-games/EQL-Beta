		<BottomAnchorToTop>false</BottomAnchorToTop>
		<TopAnchorOffset>36</TopAnchorOffset>
		<BottomAnchorOffset>2</BottomAnchorOffset>
		<LeftAnchorOffset>2</LeftAnchorOffset>
		<RightAnchorOffset>69</RightAnchorOffset>
		<TooltipReference>Click here to retrieve your item</TooltipReference>
		<Text>Retrieve</Text>
		<Template>BDT_Normal</Template>
	</Button>

	<Button item="DH_Selected_Item_Slot">
		<ScreenID>DH_Selected_Item_Slot</ScreenID>

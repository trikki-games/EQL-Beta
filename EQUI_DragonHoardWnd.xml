<?xml version = "1.0"?>
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes"/>

	<Label item="DH_Item_Count_Label">
		<ScreenID>DH_Item_Count_Label</ScreenID>
		<Location>
			<X>5</X>
			<Y>5</Y>
		</Location>
		<Size>
			<CX>128</CX>
			<CY>14</CY>
		</Size>
		<Text>Total Count:</Text>
		<NoWrap>true</NoWrap>
	</Label>

	<Label item="DH_Item_Count_Number">
		<ScreenID>DH_Item_Count_Number</ScreenID>
		<Location>
			<X>75</X>
			<Y>5</Y>
		</Location>
		<Size>
			<CX>64</CX>
			<CY>14</CY>
		</Size>

	<!-- Loot list screen -->

	<Listbox item="ADLW_LootList">
		<ScreenID>ADLW_LootList</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<TextColor>
			<R>0</R>
			<G>148</G>
			<B>255</B>
		</TextColor>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>-2</TopAnchorOffset>
		<BottomAnchorOffset>28</BottomAnchorOffset>
		<LeftAnchorOffset>-2</LeftAnchorOffset>
		<RightAnchorOffset>-2</RightAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<Style_VScroll>true</Style_VScroll>
		<Style_Border>true</Style_Border>
		<Columns>
			<Width>45</Width>
			<Heading>Item</Heading>
			<Sortable>true</Sortable>
		</Columns>
		<Columns>
			<Width>65</Width>
			<Heading>Loot</Heading>
			<Sortable>false</Sortable>
			<Tooltip>Loot item(s) on corpse(s)</Tooltip>
		</Columns>
		<Columns>
			<Width>65</Width>
			<Heading>Merge</Heading>
			<Sortable>false</Sortable>
			<Tooltip>Merge item(s) on corpse(s) with first matching inventory item</Tooltip>
		</Columns>
		<Columns>
			<Width>65</Width>
			<Heading>Store</Heading>
			<Sortable>true</Sortable>
			<Tooltip>Store item(s) on corpse(s) to either tradeskill depo or item hoard</Tooltip>
		</Columns>
		<Columns>
			<Width>65</Width>
			<Heading>Sell</Heading>
			<Sortable>true</Sortable>
			<Tooltip>Sell item(s) on corpse(s) immediately</Tooltip>
		</Columns>
		<Columns>
			<Width>200</Width>
			<Heading>Item Name</Heading>
			<Sortable>true</Sortable>
			<Tooltip>Item Name</Tooltip>
		</Columns>
		<Columns>
			<Width>200</Width>
			<Heading>NPC Name</Heading>
			<Sortable>true</Sortable>
			<Tooltip>NPC Name</Tooltip>
		</Columns>
		<TooltipReference>Trigger loot decisions here for each item.</TooltipReference>
	</Listbox>

